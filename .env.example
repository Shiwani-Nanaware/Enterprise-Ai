# =============================================================================
# Enterprise AI Knowledge Assistant — Environment Variables
# MongoDB + ChromaDB edition
# =============================================================================
# Copy this file to .env and fill in all values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Enterprise AI Knowledge Assistant"
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME="Enterprise AI Knowledge Assistant"
VITE_APP_ENV=development

# -----------------------------------------------------------------------------
# MongoDB Atlas
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<AppName>
DATABASE_NAME=finsolve_ai

# Local MongoDB (for development without Atlas):
# MONGODB_URI=mongodb://localhost:27017
# DATABASE_NAME=finsolve_ai

# -----------------------------------------------------------------------------
# Redis (optional — for caching, session storage)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# LLM Provider (OpenAI compatible — also works with Groq)
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# LLM Provider — Groq (chat only, no embeddings)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=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
OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_CHAT_MODEL=llama3-70b-8192
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# -----------------------------------------------------------------------------
# Embeddings — HuggingFace local (no API key required)
# Model downloads once (~33 MB) and is cached in ~/.cache/huggingface/
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# -----------------------------------------------------------------------------
# ChromaDB Vector Store (local persistent storage)
# -----------------------------------------------------------------------------
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION_NAME=enterprise_knowledge

# -----------------------------------------------------------------------------
# Document Storage
# -----------------------------------------------------------------------------
DOCUMENT_STORAGE_PATH=./storage/documents
MAX_DOCUMENT_SIZE_MB=50
ALLOWED_DOCUMENT_TYPES=pdf,docx,txt,md,csv

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100
RAG_TOP_K_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Monitoring & Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
ENABLE_METRICS=true
METRICS_PORT=9090
